# ─── Revamp Consulting LLC — Environment Variables ────────────────────────────
#
# Copy this file to .env.local (git-ignored) and fill in your values.
# Never commit real keys or webhook URLs to version control.
#
# ─── Lead Form Endpoint ───────────────────────────────────────────────────────
#
# Point VITE_LEAD_FORM_ENDPOINT at any of the following:
#   • Airtable automation webhook:
#       https://hooks.airtable.com/workflows/v1/<TOKEN>/...
#   • Make (Integromat) webhook:
#       https://hook.eu1.make.com/<TOKEN>
#   • Zapier webhook:
#       https://hooks.zapier.com/hooks/catch/<ID>/<TOKEN>/
#   • Your own backend API route:
#       https://api.revampconsulting.ng/leads
#
# Leave blank to run in dev-log mode (payloads printed to browser console).
VITE_LEAD_FORM_ENDPOINT=
